# ============================================================
# env.local.example
# Copy this file to .env.local and fill in the values.
# .env.local is ignored by Git (see .gitignore).
# ============================================================

# --- Supabase public credentials ---
# Required for Supabase reads. Both values are safe to expose
# in the browser (they use the anon/public role only).
# Find these in your Supabase project: Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Listing source mode ---
# Controls whether the facilities page reads from Supabase or static seed data.
#
# "static"                     → always use static seed data (safe default)
# "supabase-facilities-preview" → read from Supabase (requires credentials above)
#
# Set to "supabase-facilities-preview" in .env.local to enable live Supabase reads.
# Leave unset or set to "static" to use seed data only.
NEXT_PUBLIC_LISTING_MODE=supabase-facilities-preview
